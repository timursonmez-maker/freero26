  {n:"Earthdoctor",       x:0.44,y:0.46,r:5, wm:0.42,t:2,        fx:0.42,fy:0.50, room:4, time:0.22,
   slot:"Teulu Dome · TBC (afternoon)", oo:20, ooNote:""},
  {n:"Tristan Arp",       x:0.46,y:0.42,r:5, wm:0.52,t:2,        fx:0.44,fy:0.46, room:2, time:0.62,
   slot:"Matrix · TBC (live)", oo:18, ooNote:""},
  {n:"Soulstatejazz",     x:0.26,y:0.46,r:5, wm:0.14,t:2,        fx:0.24,fy:0.50, room:4, time:0.18,
   slot:"Teulu Dome · TBC (live, afternoon)", oo:12, ooNote:""},
  {n:"Jo Johnson",        x:0.48,y:0.50,r:5, wm:0.32,t:2,        fx:0.46,fy:0.54, room:5, time:0.60,
   slot:"Dreamtime · TBC (live)", oo:16, ooNote:""},
  {n:"Ilmajaam",          x:0.54,y:0.44,r:5, wm:0.44,t:2,        fx:0.52,fy:0.48, room:3, time:0.52,
   slot:"Sammy String's · TBC", oo:18, ooNote:""},
  {n:"Another Planet 9",  x:0.58,y:0.62,r:5, wm:0.30,t:2,        fx:0.56,fy:0.66, room:1, time:0.35,
   slot:"KITH · TBC (live)", oo:14, ooNote:""},
  {n:"Yushh",             x:0.36,y:0.16,r:5, wm:0.62,t:2,        fx:0.34,fy:0.20, room:2, time:0.52,
   slot:"Matrix · TBC", oo:22, ooNote:""},
  {n:"Alex Downey",       x:0.50,y:0.48,r:5, wm:0.36,t:2,        fx:0.48,fy:0.52, room:3, time:0.75,
   slot:"Sammy String's · TBC", oo:20, ooNote:""},
];

function lerp(t,c1,c2){
  const h=s=>[parseInt(s.slice(1,3),16),parseInt(s.slice(3,5),16),parseInt(s.slice(5,7),16)];
  const a=h(c1),b=h(c2);
  return'rgb('+[0,1,2].map(i=>Math.round(a[i]+(b[i]-a[i])*t)).join(',')+')';
}
const WARM='#C9844A',COLD='#7abbe0',ZONE='#1D9E75';
const OP=[0.94,0.82,0.50];

const svg=document.getElementById('matrixSvg');
const tip=document.getElementById('matrixTip');
const wrap=svg.closest('.matrix-wrap');
const gc='#16202a',ac='#1e2d3c',bg='#0b0f13';

function el(tag,a){
  const e=document.createElementNS('http://www.w3.org/2000/svg',tag);
  for(const[k,v]of Object.entries(a))e.setAttribute(k,v);
  return e;
}

// Fix tooltip: wrapped, multi-line
tip.style.maxWidth='260px';
tip.style.whiteSpace='normal';
tip.style.lineHeight='1.5';

svg.appendChild(el('rect',{x:P.l,y:P.t,width:PW,height:PH,fill:bg,rx:3}));
for(const v of[0.25,0.5,0.75]){
  svg.appendChild(el('line',{x1:px(v),y1:P.t,x2:px(v),y2:P.t+PH,stroke:gc,'stroke-width':'0.5','stroke-dasharray':'3,5'}));
  svg.appendChild(el('line',{x1:P.l,y1:py(v),x2:P.l+PW,y2:py(v),stroke:gc,'stroke-width':'0.5','stroke-dasharray':'3,5'}));
}
svg.appendChild(el('line',{x1:P.l,y1:py(0.5),x2:P.l+PW,y2:py(0.5),stroke:ac,'stroke-width':'1.2'}));
svg.appendChild(el('line',{x1:px(0.5),y1:P.t,x2:px(0.5),y2:P.t+PH,stroke:ac,'stroke-width':'1.2'}));

const qs='rgba(255,255,255,0.08)';
[
  {t:'ambient + straight',x:P.l+8,y:P.t+14,a:'start'},
  {t:'ambient + broken',x:P.l+PW-8,y:P.t+14,a:'end'},
  {t:'hard + straight',x:P.l+8,y:P.t+PH-7,a:'start'},
  {t:'hard + broken',x:P.l+PW-8,y:P.t+PH-7,a:'end'},
].forEach(q=>{
  const e=el('text',{x:q.x,y:q.y,'text-anchor':q.a,style:`font-size:9px;letter-spacing:.06em;text-transform:uppercase;fill:${qs};font-family:Martian Mono,monospace;`});
  e.textContent=q.t;svg.appendChild(e);
});
[
  {t:'← straight',x:P.l,y:P.t+PH+18,a:'start'},
  {t:'broken →',x:P.l+PW,y:P.t+PH+18,a:'end'},
  {t:'ambient',x:P.l-6,y:P.t+5,a:'end'},
  {t:'hard',x:P.l-6,y:P.t+PH,a:'end'},
].forEach(q=>{
  const e=el('text',{x:q.x,y:q.y,'text-anchor':q.a,style:`font-size:10px;fill:#485f70;font-family:Martian Mono,monospace;`});
  e.textContent=q.t;svg.appendChild(e);
});

const dynLayer=el('g',{});
svg.appendChild(dynLayer);

let ffOn=false,roomFilter='all',timeVal=50,ooMin=0;

function timeFactor(t){const tv=timeVal/100;return Math.max(0.18,1-Math.abs(t-tv)*1.6);}

function render(){
  while(dynLayer.firstChild)dynLayer.removeChild(dynLayer.firstChild);
  const placed=[],bgc='rgba(6,8,9,0.84)';
  const sorted=[...A].sort((a,b)=>b.r-a.r);

  for(const a of sorted){
    const rm=roomFilter==='all'||a.room===parseInt(roomFilter);
    const tf=timeFactor(a.time);
    const om=a.oo>=ooMin;
    const tx=ffOn?a.fx:a.x,ty=ffOn?a.fy:a.y;
    const cx=px(tx),cy=py(ty);
    const op=OP[a.t]*tf*(rm?1:0.10)*(om?1:0.08);
    const col=a.t===0?ZONE:lerp(a.wm,WARM,COLD);

    if(ffOn&&(Math.abs(tx-a.x)>0.01||Math.abs(ty-a.y)>0.01)){
      const gx=px(a.x),gy=py(a.y);
      dynLayer.appendChild(el('circle',{cx:gx,cy:gy,r:a.r,fill:'none',stroke:col,'stroke-width':'1','stroke-dasharray':'3,3',opacity:rm&&om?'0.28':'0.06'}));
      dynLayer.appendChild(el('line',{x1:gx,y1:gy,x2:cx,y2:cy,stroke:col,'stroke-width':'0.8',opacity:rm&&om?'0.22':'0.05','stroke-dasharray':'2,3'}));
    }

    const g=el('g',{});
    g.style.cursor='pointer';g.style.opacity=op;
    g.appendChild(el('circle',{cx,cy,r:a.r,fill:col,stroke:'rgba(0,0,0,0.35)','stroke-width':'1'}));
    if(a.star)g.appendChild(el('circle',{cx,cy,r:a.r+4,fill:'none',stroke:ZONE,'stroke-width':'1.5',opacity:'0.4'}));

    if((om&&ooMin>0)||a.oo>=70){
      const rr=a.r+3+(a.oo/100)*8;
      g.appendChild(el('circle',{cx,cy,r:rr,fill:'none',stroke:'#c9a46a','stroke-width':'1','stroke-dasharray':Math.round(a.oo/20)+',3',opacity:String(Math.max(0.18,(a.oo-40)/60)*0.8)}));
    }
    if(roomFilter!=='all'&&rm){
      const rc={1:'#c98bb0',2:'#8ecfaa',3:'#c9a46a',4:'#7abbe0',5:'#b2c6b4'}[a.room]||'#888';
      g.appendChild(el('circle',{cx,cy,r:a.r+3,fill:'none',stroke:rc,'stroke-width':'1.5',opacity:'0.55'}));
    }

    const xd=a.x<0.33?'straight':a.x<0.66?'mixed':'broken';
    const yd=a.y>0.66?'ambient':a.y>0.33?'mid':'hard';
    const cd=a.wm<0.33?'warm':a.wm<0.66?'mid':'cold';

    g.addEventListener('mouseenter',()=>{
      tip.style.opacity='1';
      let h='<div style="font-family:Fraunces,serif;font-size:14px;color:#dce8e4;margin-bottom:5px;">'+a.n+'</div>';
      h+='<div style="font-family:Martian Mono,monospace;font-size:9px;line-height:1.8;">';
      h+='<div style="color:#485f70;">'+xd+' · '+yd+' · '+cd+'</div>';
      h+='<div style="color:#7abbe0;margin-top:1px;">'+a.slot+'</div>';
      h+='<div style="color:#c9a46a;margin-top:1px;">x-OO: '+a.oo+'/100</div>';
      if(a.ooNote)h+='<div style="color:#7a6040;margin-top:2px;">'+a.ooNote+'</div>';
      h+='</div>';
      tip.innerHTML=h;
      g.style.opacity='1';
    });
    g.addEventListener('mousemove',ev=>{
      const r=wrap.getBoundingClientRect();
      let left=ev.clientX-r.left+16;
      if(left+270>r.width)left=ev.clientX-r.left-276;
      tip.style.left=left+'px';
      tip.style.top=(ev.clientY-r.top-20)+'px';
    });
    g.addEventListener('mouseleave',()=>{tip.style.opacity='0';g.style.opacity=op;});
    dynLayer.appendChild(g);
  }

  const vis=A.filter(a=>(roomFilter==='all'||a.room===parseInt(roomFilter))&&timeFactor(a.time)>0.4&&a.oo>=ooMin&&(a.t<=1||a.r>=9)).sort((a,b)=>a.t-b.t||b.r-a.r);
  for(const l of vis){
    const lcx=px(ffOn?l.fx:l.x),lcy=py(ffOn?l.fy:l.y);
    const cw=l.n.length*5.8,ch=11;
    const cands=[
      {dx:l.r+5,dy:-5,an:'start'},{dx:-l.r-5,dy:-5,an:'end'},
      {dx:l.r+5,dy:7,an:'start'},{dx:-l.r-5,dy:7,an:'end'},
      {dx:0,dy:-(l.r+7),an:'middle'},{dx:0,dy:l.r+15,an:'middle'},
      {dx:l.r+5,dy:-16,an:'start'},{dx:-l.r-5,dy:-16,an:'end'},
      {dx:l.r+5,dy:20,an:'start'},{dx:-l.r-5,dy:20,an:'end'},
      {dx:l.r+18,dy:0,an:'start'},{dx:-l.r-18,dy:0,an:'end'},
    ];
    let best=cands[0],bs=Infinity;
    for(const c of cands){
      const ttx=lcx+c.dx,tty=lcy+c.dy;
      let lx=c.an==='end'?ttx-cw:c.an==='middle'?ttx-cw/2:ttx;
      const inB=lx>P.l-4&&lx+cw<W-P.r+4&&tty-ch>P.t-4&&tty<H-P.b+4;
      let olap=0;
      for(const p of placed){
        const ox=p.an==='end'?p.tx-p.cw:p.an==='middle'?p.tx-p.cw/2:p.tx;
        const ow=Math.max(0,Math.min(lx+cw,ox+p.cw)-Math.max(lx,ox));
        const oh=Math.max(0,Math.min(tty,p.ty)-Math.max(tty-ch,p.ty-ch));
        if(ow>0&&oh>0)olap+=ow*oh;
      }
      let dp=0;
      for(const ad of A){
        const ax=px(ffOn?ad.fx:ad.x),ay=py(ffOn?ad.fy:ad.y);
        const dd=Math.sqrt((ttx-ax)**2+(tty-ay)**2);
        if(dd<20)dp+=(20-dd)*4;
      }
      const sc=olap*4+dp+(inB?0:5000);
      if(sc<bs){bs=sc;best=c;}
    }
    const ftx=lcx+best.dx,fty=lcy+best.dy;
    placed.push({tx:ftx,ty:fty,cw,an:best.an});
    let bx=best.an==='end'?ftx-cw:best.an==='middle'?ftx-cw/2:ftx;
    dynLayer.appendChild(el('rect',{x:bx-2,y:fty-ch+2,width:cw+4,height:ch+1,fill:bgc,rx:'2'}));
    const fc=l.t===0?'#7ecaa4':'#8888cc';
    const te=el('text',{x:ftx,y:fty,'text-anchor':best.an,style:'font-size:10px;fill:'+fc+';font-family:Martian Mono,monospace;'});
    te.textContent=l.n;dynLayer.appendChild(te);
  }
}

document.getElementById('ffToggle').addEventListener('click',function(){ffOn=!ffOn;this.classList.toggle('on',ffOn);render();});
document.querySelectorAll('.rbtn[data-room]').forEach(btn=>{
  btn.addEventListener('click',function(){
    document.querySelectorAll('.rbtn[data-room]').forEach(b=>b.classList.remove('on'));
    this.classList.add('on');roomFilter=this.dataset.room;render();
  });
});
document.getElementById('timeSlider').addEventListener('input',function(){
  timeVal=parseInt(this.value);
  const v=timeVal/100;
  document.getElementById('timeLbl').textContent=v<0.2?'Afternoon (12–18h)':v<0.4?'Early evening (18–22h)':v<0.6?'Night (22h–02h)':v<0.8?'Late night (02–04h)':'Closing (04–05h)';
  render();
});
document.getElementById('ooSlider').addEventListener('input',function(){
  ooMin=parseInt(this.value);
  const lbl=document.getElementById('ooLbl');
  lbl.textContent=ooMin===0?'Showing all':ooMin<30?'x-OO ≥'+ooMin+' — occasional oi ois':ooMin<55?'x-OO ≥'+ooMin+' — reliable oi ois':ooMin<75?'x-OO ≥'+ooMin+' — peak oi oi territory':'x-OO ≥'+ooMin+' — certified oi oi merchants';
  render();
});

render();
})();
</script>
</body>
</html>
